{
  "name": "intertangle",
  "version": "0.1.1",
  "description": "Explore TS/JS import graphs on an infinite canvas",
  "type": "module",
  "bin": {
    "intertangle": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsup",
    "build:web": "vite build web",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "cmdk": "^1.0.0",
    "dependency-cruiser": "^16.3.0",
    "elkjs": "^0.9.3",
    "json5": "^2.2.3",
    "lucide-react": "^1.20.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "shiki": "^1.6.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsup": "^8.0.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
