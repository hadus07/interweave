{
  "name": "intertangle",
  "version": "0.1.0",
  "description": "Explore TS/JS import graphs on an infinite canvas",
  "type": "module",
  "author": "Ibrohim Bahromov",
  "license": "MIT",
  "keywords": [
    "import-graph",
    "dependency-graph",
    "typescript",
    "javascript",
    "visualization",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hadus07/intertangle.git"
  },
  "bugs": {
    "url": "https://github.com/hadus07/intertangle/issues"
  },
  "homepage": "https://github.com/hadus07/intertangle#readme",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "intertangle": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsup",
    "build:web": "vite build web",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "cmdk": "^1.0.0",
    "dependency-cruiser": "^16.3.0",
    "elkjs": "^0.9.3",
    "ignore": "^7.0.5",
    "json5": "^2.2.3",
    "lucide-react": "^1.20.0",
    "open": "^10.1.0",
    "react": "^19",
    "react-dom": "^19",
    "react-resizable-panels": "^2.1.9",
    "shiki": "^1.6.0",
    "tailwind-merge": "^3.6.0",
    "typescript": "^5.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "latest",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
